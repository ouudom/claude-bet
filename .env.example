# the-odds-api.com free tier key (500 req/mo). Sign up: https://the-odds-api.com
ODDS_API_KEY=

# Claude prediction (models/claude.py) auth resolves from the Claude Code profile /
# `ant auth login` OAuth — no ANTHROPIC_API_KEY needed.

# Telegram bot push (pipeline/notify.py). Create a bot via @BotFather -> token.
# chat_id: message the bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
